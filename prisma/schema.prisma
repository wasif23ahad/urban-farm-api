// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  ADMIN
  VENDOR
  CUSTOMER
}

enum Status {
  PENDING
  APPROVED
  CANCELLED
  COMPLETED
}

enum CertStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(CUSTOMER)
  status        String         @default("ACTIVE")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  vendorProfile VendorProfile?
  orders        Order[]
  posts         CommunityPost[]
  comments      Comment[]
  plants        Plant[]
}

model VendorProfile {
  id                  String               @id @default(uuid())
  userId              String               @unique
  user                User                 @relation(fields: [userId], references: [id])
  farmName            String
  certificationStatus CertStatus           @default(PENDING)
  farmLocation        String
  products            Produce[]
  rentalSpaces        RentalSpace[]
  orders              Order[]
  sustainabilityCerts SustainabilityCert[]
}

model Produce {
  id                  String     @id @default(uuid())
  vendorId            String
  vendor              VendorProfile @relation(fields: [vendorId], references: [id])
  name                String
  description         String
  price               Float
  category            String
  certificationStatus CertStatus @default(PENDING)
  availableQuantity   Int
  orders              Order[]
  createdAt           DateTime   @default(now())
}

model RentalSpace {
  id           String        @id @default(uuid())
  vendorId     String
  vendor       VendorProfile @relation(fields: [vendorId], references: [id])
  location     String
  size         String
  price        Float
  availability Boolean       @default(true)
  createdAt    DateTime      @default(now())
  plants       Plant[]
}

model Order {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  produceId String?
  produce   Produce?       @relation(fields: [produceId], references: [id])
  vendorId  String
  vendor    VendorProfile @relation(fields: [vendorId], references: [id])
  status    Status        @default(PENDING)
  orderDate DateTime      @default(now())
}

model CommunityPost {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String?
  postContent String
  postDate    DateTime  @default(now())
  comments    Comment[]
}

model Comment {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id])
  content   String
  parentId  String?
  parent    Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[]     @relation("CommentReplies")
  createdAt DateTime      @default(now())
}

model SustainabilityCert {
  id                String        @id @default(uuid())
  vendorId          String
  vendor            VendorProfile @relation(fields: [vendorId], references: [id])
  certifyingAgency  String
  certificationDate DateTime
  createdAt         DateTime      @default(now())
}

enum PlantStatus {
  HEALTHY
  NEEDS_ATTENTION
  DORMANT
  HARVESTED
}

model Plant {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  rentalSpaceId String?
  rentalSpace   RentalSpace? @relation(fields: [rentalSpaceId], references: [id])
  name          String
  species       String?
  growthStage   String       @default("SEEDLING")
  status        PlantStatus  @default(HEALTHY)
  healthNotes   String?
  plantedAt     DateTime     @default(now())
  lastChecked   DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

